# App
APP_NAME=FlowEngine
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql+asyncpg://flowuser:flowpass@postgres:5432/flowengine
SYNC_DATABASE_URL=postgresql://flowuser:flowpass@postgres:5432/flowengine

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
SURGE_THRESHOLD_PER_SECOND=10
